---
// MasonryBoard.astro
// Usage: pass an array of image URLs as the `images` prop

interface Props {
	images: string[];
	gap?: number;
	minColWidth?: number;
}

const { images, gap = 12, minColWidth = 220 } = Astro.props;
---

<div class='masonry-board' data-gap={gap} data-min-col-width={minColWidth}>
	{
		images.map((src) => (
			<div class='masonry-item'>
				<img src={src} alt='' loading='lazy' />
			</div>
		))
	}
</div>

<style>
	.masonry-board {
		position: relative;
		width: 100%;
	}

	.masonry-item {
		position: absolute;
		overflow: hidden;
		border-radius: 8px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.masonry-item.visible {
		opacity: 1;
	}

	.masonry-item img {
		width: 100%;
		display: block;
	}
</style>

<script>
	function layoutMasonry(board: HTMLElement) {
		const gap = Number(board.dataset.gap) || 12;
		const minColWidth = Number(board.dataset.minColWidth) || 220;
		const boardWidth = board.clientWidth;

		const columns = Math.max(
			1,
			Math.floor((boardWidth + gap) / (minColWidth + gap))
		);
		const columnWidth = (boardWidth - gap * (columns - 1)) / columns;
		const columnHeights = new Array(columns).fill(0);

		const items = board.querySelectorAll<HTMLElement>('.masonry-item');

		items.forEach((item) => {
			const shortestColumnIndex = columnHeights.indexOf(
				Math.min(...columnHeights)
			);

			item.style.width = `${columnWidth}px`;
			item.style.left = `${shortestColumnIndex * (columnWidth + gap)}px`;
			item.style.top = `${columnHeights[shortestColumnIndex]}px`;

			columnHeights[shortestColumnIndex] += item.offsetHeight + gap;
			item.classList.add('visible');
		});

		board.style.height = `${Math.max(...columnHeights)}px`;
	}

	function initBoard(board: HTMLElement) {
		const images = board.querySelectorAll<HTMLImageElement>('img');
		let loaded = 0;

		function tryLayout() {
			loaded++;
			if (loaded === images.length) layoutMasonry(board);
		}

		images.forEach((img) => {
			if (img.complete) {
				tryLayout();
			} else {
				img.addEventListener('load', tryLayout);
				img.addEventListener('error', tryLayout); // still layout even if image fails
			}
		});

		// Fallback: layout after 2s regardless
		setTimeout(() => layoutMasonry(board), 2000);
	}

	// Re-layout on resize
	let resizeTimer: ReturnType<typeof setTimeout>;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimer);
		resizeTimer = setTimeout(() => {
			document
				.querySelectorAll<HTMLElement>('.masonry-board')
				.forEach(layoutMasonry);
		}, 60);
	});

	// Init on load
	document.querySelectorAll<HTMLElement>('.masonry-board').forEach(initBoard);
</script>
