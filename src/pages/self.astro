---
import Layout from '../layouts/Layout.astro';
import styles from './self.module.scss';
---

<Layout title='Self'>
	<div class={styles.pageWrapper}>
		<div class={styles.contentWrapper}>
			<a href='/home'><img src='coolcat.webp' alt='cool cat' /></a>
			<div class={styles.imagePositionWrapper}>
				<div class={styles.imageWrapper}>
					<div class={styles.vinylWrapper}>
						<img
							src='Vinyl.webp'
							alt='vinyl'
							id='spin-img'
							class={styles.vinyl}
						/>
						<img
							src='pointer.webp'
							alt='pointer'
							class={styles.pointer}
							id='spin-pointer'
						/>
					</div>
				</div>
			</div>
			<div class={styles.textPositionWrapper}>
				<div class={styles.textWrapper}>
					<p id='spin-text'></p>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	const textMap: Record<number, string> = {
		0: '<strong>My Favorite Movies</strong><br>Memories of Murder — Bong Joon-ho<br>The Wind Rises — Miyazaki Hayao',
		45: '<strong>My Favorite Songs</strong><br>Yanqui U.X.O — Godspeed You! Black Emperor<br>A Quick One Before The Eternal Worm Devours Connecticut — Have A Nice Life<br>Doctor Gradus Ad Parnassum — Debussy<br>Touch — Daft Punk',
		90: '<strong>My Favorite Books</strong><br>The Screwtape Letters — C.S. Lewis<br>Slaughterhouse-Five — Kurt Vonnegut<br>The Sirens of Titan — Kurt Vonnegut<br>Snow Country - Yasunari Kawabata',
		135: '<strong>My Favorite Albums</strong><br>Yanqui U.X.O — Godspeed You! Black Emperor<br>Bitches Brew — Miles Davis<br>Donda — Kanye West<br>Kids See Ghosts — Kids See Ghosts<br>Drukqs — Aphex Twin',
		180: '<strong>My Favorite Artists</strong><br>JPEGMAFIA<br>Godspeed You! Black Emperor<br>Mahler<br>Mike Dean<br>Swans',
		225: '<strong>My Favorite Foods</strong><br>Red Velvet Cake<br>Ramen<br>Melon Pan',
		270: '<strong>My Favorite Colors</strong><br>Purple<br>Chrome Silver<br>Jet Black',
		315: '<strong>My Favorite Words</strong><br>Tralfamadorian<br>Kafkaesque<br>Atonement',
	};

	function init() {
		const img = document.getElementById('spin-img') as HTMLImageElement;
		const text = document.getElementById('spin-text');
		if (!img || !text) return;

		const freshImg = img.cloneNode(true) as HTMLImageElement;
		img.replaceWith(freshImg);

		const pointer = document.getElementById('spin-pointer') as HTMLImageElement;

		let currentRotation = 0;
		text.innerHTML = textMap[0];

		let isAnimating = false;

		const handleClick = () => {
			if (isAnimating) return;
			isAnimating = true;

			currentRotation = (currentRotation + 45) % 360;
			freshImg.style.transform = `rotate(${currentRotation}deg)`;
			freshImg.style.transition = 'transform 0.4s ease';

			text.style.transition = 'opacity 0.2s ease';
			text.style.opacity = '0';

			setTimeout(() => {
				text.innerHTML = textMap[currentRotation];
				text.style.opacity = '1';

				setTimeout(() => {
					isAnimating = false;
				}, 200);
			}, 200);
		};

		freshImg.addEventListener('click', handleClick);
		pointer?.addEventListener('click', handleClick);
	}

	document.addEventListener('DOMContentLoaded', init);
</script>
